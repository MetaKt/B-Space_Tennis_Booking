# Normalize line endings: store as LF in the repo, checkout as native on each OS
* text=auto
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.html text eol=lf
*.env text eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.pdf binary
*.ico binary
